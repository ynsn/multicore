OUTPUT_DIRECTORY       = @CMAKE_SOURCE_DIR@/docs/out/docs/
INPUT                  = @CMAKE_SOURCE_DIR@/include/
RECURSIVE              = YES
ALIASES                += cpp="\par Since C++^^"
ALIASES                += equivalent="\par STL equivalend: ^^"
ALIASES                += fail="\par May fail with: ^^"

PROJECT_NAME           = @PROJECT_NAME@

GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_EXTRA_STYLESHEET  = @CMAKE_SOURCE_DIR@/external/doxygen-awesome-css/doxygen-awesome.css \
                         @CMAKE_SOURCE_DIR@/external/doxygen-awesome-css/doxygen-awesome-sidebar-only.css
HTML_COLORSTYLE        = LIGHT